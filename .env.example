# Onyx Cloud base URL
ONYX_BASE_URL=https://cloud.onyx.app

# Auth cookie(s) — comma-separated for multiple accounts
# Get this from browser DevTools after logging into Onyx Cloud
ONYX_AUTH_COOKIE=your-fastapiusersauth-cookie-here

# Persona ID (0 = default, no persona)
ONYX_PERSONA_ID=0

# Origin string for Onyx API payload (enum: "webapp", "api", etc.)
ONYX_ORIGIN=webapp

# Origin URL for HTTP Origin header (defaults to ONYX_BASE_URL)
ONYX_ORIGIN_URL=https://cloud.onyx.app

# Referer header for Onyx API requests
ONYX_REFERER=https://cloud.onyx.app/app

# Optional API key to protect your proxy endpoints
# API_KEY=your-secret-api-key

# Server port
PORT=8897

# Log level (trace, debug, info, warn, error)
LOG_LEVEL=info

# Request timeout in seconds
REQUEST_TIMEOUT=300
